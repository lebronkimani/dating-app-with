# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Server Configuration
PORT=3001

# PostgreSQL Database (required for 5M+ records)
# Make sure PostgreSQL is installed and running
DB_HOST=localhost
DB_PORT=5432
DB_NAME=datingapp
DB_USER=postgres
DB_PASSWORD=your_password_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# App Name
APP_NAME=GlobalConnect

# Email Configuration (for OTP verification)
# SendGrid (recommended)
SENDGRID_API_KEY=

# Or use SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@globalconnect.com

# Content Moderation APIs
OPENAI_API_KEY=
OPEN_MODERATION_KEY=

# Azure Content Safety (for nudity detection)
AZURE_CONTENT_SAFETY_KEY=
AZURE_CONTENT_SAFETY_ENDPOINT=

# Google Vision API (for image analysis)
GOOGLE_VISION_KEY=

# Security & Encryption
ENCRYPTION_KEY=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Face++ API (for face age estimation and face similarity)
FACEPLUSPLUS_API_KEY=
FACEPLUSPLUS_API_SECRET=

# AWS Rekognition (alternative for face analysis)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=

# IPInfo API (for VPN detection)
IPINFO_API_KEY=

# IPQualityScore (for advanced VPN/proxy detection)
IPQUALITYSCORE_API_KEY=